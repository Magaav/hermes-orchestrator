# =============================================================================
# Hermes Orchestrator — .gitignore
# =============================================================================

# Clone runtime data (LARGE — per-node container filesystems)
agents/
backups/

# Logs
logs/
*.log

# Python
__pycache__/
*.py[cod]
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg

# venv / uv
.venv/
venv/
.uv/

# Node
node_modules/

# State databases
*.db
*.sqlite3
*.sqlite3-wal
*.sqlite3-shm
state.db*
sessions/

# Audio / browser cache
audio_cache/
browser_screenshots/
memories/

# Environment files (contain secrets)
.env
.env.*
*.env.local
secrets/
credentials/

# OS
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDE
.vscode/
.idea/
*.iml

# Cryptographic keys
*.pem
*.key
*.p12
*.jks

# Docker
.docker/

# Nix
result
result-*
*.drv

# Local package manager artifacts
*.snap
*.flatpak

# Test coverage
.coverage
htmlcov/
.pytest_cache/

# Trajectories / replays
trajectories/
replays/

# Temporary files
tmp/
temp/
*.tmp

# Embedded git repositories (not submodules — converted to regular dirs)
hermes-agent/.git
.hermes/hermes-agent/.git
.hermes/workspace/github-package/.git
.hermes/workspace/hermes-agent-self-evolution/.git

# Node state (root-owned, runtime data)
spawns/colmeio/.hermes
spawns/catatau/.hermes
spawns/orchestrator/.hermes

# Recursively exclude all .git directories
.git/

# Also specifically the embedded ones
.hermes/hermes-agent/.git/
.hermes/workspace/github-package/.git/
.hermes/workspace/hermes-agent-self-evolution/.git/
.hermes/node/bin/node
.hermes/workspace/user/hermes-full-backup
