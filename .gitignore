**/__pycache__/
**/*.py[cod]
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
**/.cache/
**/node_modules/

# Local virtual environments
.venv/
venv/
hermes-agent/.venv/
hermes-agent/venv/

