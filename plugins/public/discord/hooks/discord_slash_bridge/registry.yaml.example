version: 1
native_overrides:
  restart:
    enabled: true
    description: Restart the Hermes gateway
    ack_message: ✅ Reinício solicitado. O gateway será reiniciado em alguns segundos.
    restart_cmd_env: COLMEIO_DISCORD_RESTART_CMD
    restart_delay_env: COLMEIO_DISCORD_RESTART_DELAY_SEC
    default_restart_cmd: sudo hermes gateway restart --system
    default_delay_sec: 0.1
    log_path: /tmp/hermes-discord-restart.log
  reboot:
    enabled: true
    description: Reboot the Hermes container
    reboot_cmd_env: COLMEIO_DISCORD_REBOOT_CMD
    reboot_delay_env: COLMEIO_DISCORD_REBOOT_DELAY_SEC
    default_reboot_cmd: "touch /tmp/hermes-reboot-requested; if [ -s /tmp/hermes-gateway.pid ]; then kill -KILL $(cat /tmp/hermes-gateway.pid); else pkill -KILL -f '/local/hermes-agent/cli.py --gateway'; fi"
    default_delay_sec: 0.2
    log_path: /tmp/hermes-discord-reboot.log
    reapplies:
      - camofox_env_bootstrap
      - openviking_env_bootstrap
      - model_env_bootstrap
      - channel_acl hook
      - gateway FIFO queue hook
      - session_info hook
      - discord guild sync
      - discord command bootstrap
  metricas:
    enabled: false
    description: Show Colmeio metrics dashboard
    acl_command: metricas
    script_path: /local/skills/custom/colmeio/colmeio-metrics/scripts/metrics_logger.py
    timeout_sec: 45
  backup:
    enabled: true
    enabled_nodes:
      - orchestrator
    group_name: backup
    command_description: Create backup for one node or all nodes and mirror to Google Drive
    acl_command: backup
    default_node: all
    node_choices:
      - orchestrator
      - colmeio
      - catatau
      - all
    clone_manager_script: /local/scripts/public/clone/clone_manager.py
    drive_script: /local/crons/colmeio/scripts/backup/drive_backup.py
    local_backup_root: /local/backups
    drive_folder_path: backups/orchestrator
    timeout_backup_sec: 1800
    timeout_drive_sec: 3600
  acl:
    enabled: true
    description: Gerenciar ACL de comandos e canais
    acl_command: acl
    command_description: "Slash command alvo (ex.: metricas)"
    role_description: "Role mínima (ex.: gerente, admin ou @everyone)"
    channel_description: "Canal alvo (channel_id numérico)"
    mode_description: "Modo: default (livre) ou specific (condicionado)"
    model_key_description: "Obrigatório em mode:specific"
    instructions_description: "Instruções extras do canal (opcional)"
    allowed_commands_description: "CSV de comandos permitidos (opcional)"
    allowed_skills_description: "CSV de skills permitidas (opcional)"
    always_allowed_description: "CSV de comandos sempre permitidos (opcional)"
    default_action_description: "Ação padrão para texto livre (opcional)"
    free_text_policy_description: "Política de texto livre (opcional)"
    label_description: "Label fixa para automações do canal (opcional)"
  model:
    enabled: true
    description: Trocar o modelo padrão do gateway
    acl_command: model
    option_description: Digite para buscar ou selecione um modelo
    usage_left_default: unlimited
    choices:
      - key: gpt54
        label: GPT-5.4 (OpenAI Codex)
        provider: openai-codex
        model: gpt-5.4
      - key: gpt53codex
        label: GPT-5.3 Codex(OpenAI Codex)
        provider: openai-codex
        model: gpt-5.3-codex
      - key: nemotron120b
        label: Nemotron 120B (NVIDIA)
        provider: nvidia
        model: nvidia/nemotron-3-super-120b-a12b
      - key: minimaxm27
        label: MiniMax M2.7
        provider: minimax
        model: MiniMax-M2.7
      - key: kimik25
        label: Kimi K2.5
        provider: kimi-coding
        model: moonshotai/kimi-k2.5
slash_bridge:
  enabled: true
  hide_skill_group: true
  force_bridge_commands: []
  commands:
    model:
      acl_command: model
      handler: model_switch
    clean:
      acl_command: clean
      handler: custom:clean
    pair:
      acl_command: pair
      handler: custom:pair
    clone:
      acl_command: clone
      handler: custom:clone
      docker_image: ubuntu:24.04
    thread:
      acl_command: thread
      handler: custom:thread
