{
  "version": 2,
  "description": "Template runtime Discord ACL for node-local workspace state.",
  "roles": {
    "admin": {
      "description": "Full access",
      "allowed_intents": [
        "*"
      ],
      "requires_admin_approval": false
    },
    "user": {
      "description": "Skill-only access with admin approval for privileged actions.",
      "allowed_intents": [
        "skill_execute"
      ],
      "requires_admin_approval_for": [
        "*"
      ],
      "forbidden_without_approval": [
        "skill_manage",
        "memory_manage",
        "config_change",
        "outside_skill",
        "system_change"
      ]
    }
  },
  "users": [],
  "channels": {
    "master": {
      "name": "master",
      "discord_channel_id": "",
      "purpose": [
        "approvals",
        "proactive_notifications"
      ]
    }
  },
  "admin_contact": {
    "name": "",
    "discord_user_id": "",
    "notification_mode": "master_channel",
    "delivery_target": ""
  },
  "proactive": {
    "enabled": false,
    "delivery_target": "",
    "immediate": {
      "enabled": true,
      "notify_on": [
        "approval_requests",
        "blocked_operations",
        "errors",
        "risky_actions"
      ]
    },
    "batched": {
      "enabled": true,
      "mode": "only_if_matters",
      "min_severity": "warning",
      "max_messages_per_hour": 1
    },
    "digest": {
      "enabled": true,
      "frequency": "daily",
      "timezone": "UTC",
      "preferred_time": "09:00",
      "only_if_matters": true
    }
  },
  "approval_flow": {
    "enabled": true,
    "states": [
      "pending",
      "approved",
      "denied",
      "cancelled"
    ],
    "default_timeout_minutes": 1440
  },
  "pending_requests": []
}
