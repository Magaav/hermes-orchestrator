{
  "version": 2,
  "updated_at": "2026-04-08T00:00:00Z",
  "description": "Example Discord ACL for hermes-orchestrator.",
  "roles": {
    "admin": {
      "description": "Full access",
      "allowed_intents": [
        "*"
      ],
      "requires_admin_approval": false
    },
    "user": {
      "description": "Skill-only access with admin approval for privileged actions.",
      "allowed_intents": [
        "skill_execute"
      ],
      "requires_admin_approval_for": [
        "*"
      ],
      "forbidden_without_approval": [
        "skill_manage",
        "memory_manage",
        "config_change",
        "outside_skill",
        "system_change"
      ]
    }
  },
  "users": [
    {
      "name": "Admin User",
      "discord_user_id": "000000000000000000",
      "aliases": [
        "admin"
      ],
      "role": "admin"
    },
    {
      "name": "Member User",
      "discord_user_id": "000000000000000001",
      "aliases": [
        "member"
      ],
      "role": "user"
    }
  ],
  "channels": {
    "master": {
      "name": "master",
      "discord_channel_id": "000000000000000000",
      "purpose": [
        "approvals",
        "proactive_notifications"
      ]
    }
  },
  "admin_contact": {
    "name": "Admin User",
    "discord_user_id": "000000000000000000",
    "notification_mode": "master_channel",
    "delivery_target": "discord:000000000000000000",
    "notes": "Replace with your admin contact/channel in local runtime config."
  },
  "proactive": {
    "enabled": true,
    "delivery_target": "discord:000000000000000000",
    "immediate": {
      "enabled": true,
      "notify_on": [
        "approval_requests",
        "blocked_operations",
        "errors",
        "risky_actions"
      ]
    },
    "batched": {
      "enabled": true,
      "mode": "only_if_matters",
      "min_severity": "warning",
      "max_messages_per_hour": 1
    },
    "digest": {
      "enabled": true,
      "frequency": "daily",
      "timezone": "UTC",
      "preferred_time": "09:00",
      "only_if_matters": true
    }
  },
  "approval_flow": {
    "enabled": true,
    "states": [
      "pending",
      "approved",
      "denied",
      "cancelled"
    ],
    "default_timeout_minutes": 1440
  },
  "pending_requests": []
}
