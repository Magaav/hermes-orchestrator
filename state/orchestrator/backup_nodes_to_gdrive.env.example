# Copy this file to:
#   /local/state/orchestrator/backup_nodes_to_gdrive.env
# and set values for your environment.

# Required Google Drive folder anchors.
# The script validates these IDs before upload and aborts if any is missing.
BACKUPS_FOLDER_ID=CHANGEME
ORCH_FOLDER_ID=CHANGEME
DAILY_FOLDER_ID=CHANGEME

# Optional: comma or space-separated node names.
# Leave empty to auto-discover all directories under BACKUP_NODES_DIR.
BACKUP_NODE_LIST=orchestrator

# Optional topology overrides.
BACKUP_LOG_ROOT=/logs/attention
BACKUP_LOCAL_DIR=/backups/orchestrator/daily
BACKUP_NODES_DIR=/local/agents/nodes
ORCHESTRATOR_ENV_FILE=/local/agents/envs/orchestrator.env

# Optional Discord DM alert target.
# Leave empty to disable DM notifications.
DISCORD_USER_ID=
