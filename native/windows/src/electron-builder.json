{
  "appId": "com.wasmagent.desktop",
  "productName": "WASM Agent",
  "copyright": "Copyright © 2026 Hermes Orchestrator",
  "directories": {
    "output": "../release",
    "buildResources": "build"
  },
  "extraResources": [
    {
      "from": "build/icon.ico",
      "to": "icon.ico"
    },
    {
      "from": "build/native-defaults.json",
      "to": "native-defaults.json"
    },
    {
      "from": "../ops",
      "to": "bridge-ops",
      "filter": [
        "**/*.js",
        "**/*.manifest.json"
      ]
    },
    {
      "from": "../../../plugins/wasm-agent/public",
      "to": "public",
      "filter": [
        "**/*",
        "!**/*.map",
        "!**/*.log",
        "!**/*.zip",
        "!**/*.apk",
        "!reports/**",
        "!build/**",
        "!dist/**",
        "!coverage/**",
        "!test/**",
        "!tests/**",
        "!tools/app-simulator/**",
        "!screenshots/**",
        "!fixtures/**",
        "!native/android/**",
        "!plugins/**/tests/**",
        "!native/releases/android/*.apk"
      ]
    },
    {
      "from": "../../../tools/horc-local/horc-local.js",
      "to": "horc/horc-local.js"
    },
    {
      "from": "../../../tools/app-simulator",
      "to": "horc/app-simulator",
      "filter": [
        "simulate.js",
        "android.js",
        "skeleton.js",
        "package.json",
        "core/**",
        "!fixtures/**",
        "!reports/**",
        "!tests/**",
        "!test/**"
      ]
    }
  ],
  "files": [
    "main.js",
    "native-backend-resolver.js",
    "native-shell-policy.js",
    "windows-self-update.js",
    "preload.js",
    "fallback.html",
    "native-defaults.json",
    "build/icon.svg",
    "package.json",
    "!reports/**",
    "!build/**",
    "!dist/**",
    "!coverage/**",
    "!test/**",
    "!tests/**",
    "!tools/app-simulator/**",
    "!native/android/**",
    "!plugins/**/tests/**",
    "!screenshots/**",
    "!fixtures/**",
    "!*.map",
    "!*.log",
    "!*.zip",
    "!*.apk"
  ],
  "asar": true,
  "publish": null,
  "win": {
    "icon": "build/icon.ico",
    "signAndEditExecutable": true,
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      }
    ],
    "artifactName": "WASM-Agent-Setup-x64.exe",
    "verifyUpdateCodeSignature": false
  },
  "linux": {
    "icon": "build/icon.svg",
    "category": "Utility",
    "target": [
      {
        "target": "AppImage",
        "arch": [
          "x64",
          "arm64"
        ]
      }
    ],
    "artifactName": "WASM-Agent-${arch}.${ext}"
  },
  "mac": {
    "category": "public.app-category.utilities",
    "target": [
      {
        "target": "dmg",
        "arch": [
          "x64",
          "arm64"
        ]
      }
    ],
    "artifactName": "WASM-Agent-${arch}.${ext}"
  },
  "nsis": {
    "guid": "8e77a95c-1554-58fc-9852-11d4a9707428",
    "installerIcon": "build/icon.ico",
    "uninstallerIcon": "build/icon.ico",
    "include": "build/installer.nsh",
    "script": "build/installer.nsi",
    "warningsAsErrors": false,
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": "always",
    "createStartMenuShortcut": true,
    "shortcutName": "WASM Agent",
    "deleteAppDataOnUninstall": false
  }
}
