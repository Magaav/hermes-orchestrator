### Agent Setup
CLONE_STATE=3
CLONE_STATE_FROM_BACKUP_PATH='/local/backups/CHANGEME.tar.gz'
CLONE_FORCE_RESEED=0
DEFAULT_MODEL_PROVIDER=minimax
DEFAULT_MODEL='MiniMax M2.7'
FALLBACK_MODEL_PROVIDER=kimi-coding
FALLBACK_MODEL=moonshotai/kimi-k2.5
AGENT_ALLOWED_COMMANDS='*'

# Optional memory/browser
BROWSER_CAMOFOX=0
CAMOFOX_URL=http://127.0.0.1:9377
MEMORY_OPENVIKING=0
OPENVIKING_ENDPOINT=http://host.docker.internal:1933
OPENVIKING_ACCOUNT=example-account
OPENVIKING_USER=colmeio

### Discord Keys
DISCORD_HOME_CHANNEL=000000000000000000
DISCORD_APP_ID=000000000000000000
DISCORD_SERVER_ID=000000000000000000
DISCORD_BOT_TOKEN=CHANGEME
DISCORD_ALLOWED_USERS='000000000000000000'

### API Keys
NVIDIA_API_KEY=CHANGEME
OPENROUTER_API_KEY=CHANGEME
MINIMAX_API_KEY=CHANGEME
MINIMAX_GROUP_ID=CHANGEME

# Codex OAuth is not env-based. Run `hermes login` in this node context
# to populate /local/agents/nodes/<node>/.hermes/auth.json.

### Optional Google Keys
GOOGLE_EMAIL_LOGIN=bot@example.com
GOOGLE_OAuth_CLIENT_ID=CHANGEME
GOOGLE_OAuth_CLIENT_SECRET=CHANGEME
GOOGLE_OAuth_REFRESH_TOKEN=CHANGEME
