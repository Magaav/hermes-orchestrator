### Orchestrator Setup (host node)
NODE_AGENT_DEFAULT_MODEL_PROVIDER=minimax
NODE_AGENT_DEFAULT_MODEL='MiniMax M2.7'
NODE_AGENT_FALLBACK_MODEL_PROVIDER=kimi-coding
NODE_AGENT_FALLBACK_MODEL=moonshotai/kimi-k2.5
NODE_AGENT_FOLLOWUP_ELAPSED='10'
NODE_AGENT_FOLLOWUP_SUMMARY=false
NODE_AGENT_FINALRESPONSE_ENFORCE_FILES_CHANGED=false
# HERMES_YOLO_MODE=1
# NODE_STATE: 1 > orchestrator | 2 > seed_from_parent_snapshot | 3 > seed_from_backup | 4 > fresh
NODE_STATE=1
NODE_STATE_FROM_BACKUP_PATH=''
# Shared markdown-native wiki (disabled by default).
NODE_WIKI_ENABLED=false
# SST (Speech-to-Text) model override.
# If omitted, defaults to whisper-large-v3-turbo.
# Supported local models: tiny, base, small, medium, large-v2, large-v3, large-v3-turbo
# Examples:
#   NODE_SST_MODEL=large-v3        # Highest accuracy, slower
#   NODE_SST_MODEL=large-v3-turbo  # Good accuracy, faster (this is the default when unset)
#   NODE_SST_LANGUAGE=pt           # Default en

# OPENVIKING
OPENVIKING_ENABLED=0
OPENVIKING_ENDPOINT=http://127.0.0.1:1933
# OPENVIKING_ACCOUNT / OPENVIKING_USER are optional.
# If omitted, both default to the node name (derived from <node>.env filename).

# CAMOFOX
CAMOFOX_ENABLED=0
CAMOFOX_URL=http://127.0.0.1:9377

### Discord Keys
DISCORD_HOME_CHANNEL=000000000000000000
DISCORD_APP_ID=000000000000000000
DISCORD_SERVER_ID=000000000000000000
DISCORD_BOT_TOKEN=CHANGEME
DISCORD_ALLOWED_USERS='000000000000000000'
DISCORD_REQUIRE_MENTION=true
DISCORD_AUTO_THREAD=true
# Optional: channels where non-mentions stay inline but @mentions still thread.
# DISCORD_AUTO_THREAD_IGNORE_CHANNELS=1487099467726328038,1487099552636080201

### API Keys
NVIDIA_API_KEY=CHANGEME
OPENROUTER_API_KEY=CHANGEME
MINIMAX_API_KEY=CHANGEME
MINIMAX_GROUP_ID=CHANGEME

# Codex OAuth is not env-based. Run `hermes login` in this node context
# to populate /local/agents/nodes/<node>/.hermes/auth.json.

### Optional Google Keys
GOOGLE_EMAIL_LOGIN=bot@example.com
GOOGLE_OAuth_CLIENT_ID=CHANGEME
GOOGLE_OAuth_CLIENT_SECRET=CHANGEME
GOOGLE_OAuth_REFRESH_TOKEN=CHANGEME
